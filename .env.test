# E2E test environment — loaded by playwright.config.ts (NOT by Next directly).
# Points at the disposable Docker Postgres from docker-compose.test.yml.
# playwright.config.ts refuses to run against any non-localhost DATABASE_URL,
# so this file must never contain a remote/production URL.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/gatepass_test"
SESSION_SECRET="e2e-test-secret"
